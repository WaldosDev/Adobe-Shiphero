NODE_ENV=development
PORT=8080

REDIS_HOST=127.0.0.1
REDIS_PORT=6379

SHIPHERO_GRAPHQL_URL=https://public-api.shiphero.com/graphql
SHIPHERO_BEARER_TOKEN=replace-with-secure-token

ADOBE_BASE_URL=https://adobe-commerce.example.com
ADOBE_ACCESS_TOKEN=replace-with-secure-token

WEBHOOK_SHARED_SECRET=replace-with-shared-secret

# Use true for local/staging smoke tests without calling ShipHero or Adobe.
DRY_RUN_EXTERNAL_APIS=true
